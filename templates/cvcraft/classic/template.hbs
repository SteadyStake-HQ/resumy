<article class="resume classic-template">
  <header class="resume-header">
    <h1>{{resume.personalInfo.name}}</h1>
    {{#if contactItems.length}}
      <p>{{join contactItems}}</p>
    {{/if}}
  </header>

  {{#if hasSummary}}
    <section class="section">
      <p class="section-heading">Professional Summary</p>
      <p class="summary">{{resume.summary}}</p>
    </section>
  {{/if}}

  {{#if hasSkills}}
    <section class="section">
      <p class="section-heading">Core Skills</p>
      {{#each skillGroups}}
        <p class="skill-line"><strong>{{label}}:</strong> {{join skills " • "}}</p>
      {{/each}}
    </section>
  {{/if}}

  {{#if hasExperience}}
    <section class="section">
      <p class="section-heading">Experience</p>
      {{#each resume.experience}}
        <article class="experience-item">
          <h2 class="experience-title">{{title}}{{#if company}} — {{company}}{{/if}}</h2>
          <p class="experience-meta">
            {{#if location}}{{location}}{{/if}}
            {{#if startDate}}{{#if location}} • {{/if}}{{startDate}}{{/if}}
            {{#if endDate}} - {{endDate}}{{/if}}
          </p>
          {{#if description.length}}
            <ul class="experience-bullets">
              {{#each description}}
                <li>{{this}}</li>
              {{/each}}
            </ul>
          {{/if}}
        </article>
      {{/each}}
    </section>
  {{/if}}

  {{#if hasEducation}}
    <section class="section">
      <p class="section-heading">Education</p>
      {{#each resume.education}}
        <article class="education-item">
          <h3 class="education-title">{{degree}}</h3>
          <p class="education-meta">{{institution}}{{#if year}} • {{year}}{{/if}}</p>
        </article>
      {{/each}}
    </section>
  {{/if}}
</article>
